#!/usr/bin/env python3

from __future__ import annotations

import sys
from pathlib import Path
from typing import List, Tuple

REPO_ROOT = Path(__file__).resolve().parents[1]
ACTIVE_DIR = REPO_ROOT / "docs" / "exec-plans" / "active"
COMPLETED_DIR = REPO_ROOT / "docs" / "exec-plans" / "completed"
EXCLUDE = {"tech-debt-tracker.md", ".gitkeep"}

UPDATED_PREFIX = "Updated:"
SECTION_ORDER = [
    "Objective",
    "Non-goals",
    "Milestones",
    "Validation",
    "Rollout",
    "Risks",
]


def _iter_plan_files() -> List[Path]:
    files: List[Path] = []
    for root in (ACTIVE_DIR, COMPLETED_DIR):
        if not root.exists():
            continue
        for path in root.rglob("*.md"):
            if path.name in EXCLUDE:
                continue
            files.append(path)
    return files


def _strip_lines(path: Path) -> List[str]:
    return [line.rstrip("\n") for line in path.read_text().splitlines()]


def _first_non_empty(lines: List[str]) -> Tuple[int, str]:
    for idx, line in enumerate(lines):
        if line.strip():
            return idx, line
    return -1, ""


def _section_header(label: str) -> str:
    return f"## {label}"


def _find_section_indices(lines: List[str]) -> List[Tuple[str, int]]:
    results: List[Tuple[str, int]] = []
    for idx, line in enumerate(lines):
        for label in SECTION_ORDER:
            if line.strip() == _section_header(label):
                results.append((label, idx))
    return results


def _find_next_heading(lines: List[str], start_idx: int) -> int:
    for idx in range(start_idx + 1, len(lines)):
        if lines[idx].strip().startswith("## "):
            return idx
    return len(lines)


def _has_details(lines: List[str], start_idx: int, end_idx: int) -> bool:
    for idx in range(start_idx + 1, end_idx):
        if lines[idx].strip():
            return True
    return False


def _validate_plan(path: Path) -> List[str]:
    errors: List[str] = []
    lines = _strip_lines(path)
    idx, first = _first_non_empty(lines)
    if idx == -1 or not first.startswith("# "):
        errors.append("missing title line starting with '# '")
        return errors

    updated_idx = -1
    for i in range(idx + 1, len(lines)):
        if lines[i].strip():
            updated_idx = i
            break
    if updated_idx == -1 or not lines[updated_idx].startswith(UPDATED_PREFIX):
        errors.append("missing 'Updated: YYYY-MM-DD' line after title")
        return errors

    section_indices = _find_section_indices(lines)
    index_by_label = {label: idx for label, idx in section_indices}
    if set(index_by_label.keys()) != set(SECTION_ORDER):
        errors.append(
            "required sections missing or out of order: " + " -> ".join(SECTION_ORDER)
        )
        return errors

    last_idx = -1
    for label in SECTION_ORDER:
        idx_val = index_by_label[label]
        if idx_val <= last_idx:
            errors.append(
                "required sections missing or out of order: "
                + " -> ".join(SECTION_ORDER)
            )
            return errors
        last_idx = idx_val

    for label in SECTION_ORDER:
        start_idx = index_by_label[label]
        end_idx = _find_next_heading(lines, start_idx)
        if not _has_details(lines, start_idx, end_idx):
            errors.append(f"section '{label}' must include details")
    return errors


def main() -> int:
    errors: List[str] = []
    for path in _iter_plan_files():
        plan_errors = _validate_plan(path)
        if plan_errors:
            for err in plan_errors:
                errors.append(f"{path}: {err}")

    if errors:
        print("[lint-plan] violations:")
        for err in errors:
            print(f"- {err}")
        return 1
    print("[lint-plan] OK")
    return 0


if __name__ == "__main__":
    sys.exit(main())
