# Local development ports
API_PORT=3401
WEB_PORT=3400

# Query generation uses a direct OpenAI Responses API call
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_QUERY_MODEL=gpt-5-mini

# Workbook pipeline generation still uses Codex CLI
CODEX_COMMAND=/Applications/Codex.app/Contents/Resources/codex

# Optional local data overrides
# SOURCE_DATABASE_PATH=.data/source-datasets.sqlite
# CLEAN_DATABASE_DIRECTORY_PATH=.data/clean-databases
